<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Glotto.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Glotto.WinUI"
    xmlns:tb="using:H.NotifyIcon">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!--
                TaskbarIcon must be declared here (in Application.Resources) for the
                H.NotifyIcon.WinUI windowless pattern to work.
                It needs a XAML host/tree to initialise correctly.
                ForceCreate() is called from App.xaml.cs OnLaunched.
            -->
            <tb:TaskbarIcon
                x:Key="TrayIcon"
                ToolTipText="Glotto - Idle (double-click to arm)"
                MenuActivation="RightClick"
                ContextMenuMode="PopupMenu">

                <tb:TaskbarIcon.IconSource>
                    <BitmapImage UriSource="ms-appx:///Assets/Square44x44Logo.targetsize-24_altform-unplated.png" />
                </tb:TaskbarIcon.IconSource>

                <tb:TaskbarIcon.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="ToggleItem" Text="Toggle Composition Mode" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="SettingsItem" Text="Settings…" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="QuitItem" Text="Quit Glotto" />
                    </MenuFlyout>
                </tb:TaskbarIcon.ContextFlyout>
            </tb:TaskbarIcon>

        </ResourceDictionary>
    </Application.Resources>
</Application>
