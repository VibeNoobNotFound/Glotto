<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Glotto.WinUI.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Glotto.WinUI.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Glotto Settings">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel Spacing="24" MaxWidth="500" HorizontalAlignment="Left">
            
            <!-- Global Shortcut Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Global Shortcut" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" 
                        Padding="16">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Toggle Glotto" FontWeight="SemiBold" />
                            <TextBlock Text="Press this shortcut in any app to arm or disarm transliteration mode." 
                                       Style="{ThemeResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        
                        <Button Grid.Row="0" Grid.Column="1" 
                                x:Name="RecordHotkeyButton"
                                Content="{x:Bind ViewModel.HotkeyText, Mode=OneWay}" 
                                Click="RecordHotkeyButton_Click" 
                                MinWidth="120"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Language Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Language" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" 
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Active Profile" FontWeight="SemiBold" />
                            <TextBlock Text="Select the active transliteration language target." 
                                       Style="{ThemeResource CaptionTextBlockStyle}" 
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{x:Bind ViewModel.LanguageProfiles}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{x:Bind ViewModel.ActiveProfileId, Mode=TwoWay}"
                                  MinWidth="120"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Transliteration Providers Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Transliteration Providers" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <TextBlock Text="Prioritize engines by moving them up or down." 
                           Style="{ThemeResource CaptionTextBlockStyle}" 
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                
                <ListView ItemsSource="{x:Bind ViewModel.Providers}" 
                          SelectionMode="None" 
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                          BorderThickness="1" 
                          CornerRadius="8" 
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ProviderItemViewModel">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Move Up/Down Controls -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                                    <Button Command="{Binding ElementName=RecordHotkeyButton, Path=DataContext.MoveUpCommand}" 
                                            CommandParameter="{Binding}" 
                                            Padding="4" Height="28" Width="28">
                                        <FontIcon Glyph="&#xE70E;" FontSize="12" />
                                    </Button>
                                    <Button Command="{Binding ElementName=RecordHotkeyButton, Path=DataContext.MoveDownCommand}" 
                                            CommandParameter="{Binding}" 
                                            Padding="4" Height="28" Width="28">
                                        <FontIcon Glyph="&#xE70D;" FontSize="12" />
                                    </Button>
                                </StackPanel>

                                <!-- Icon -->
                                <FontIcon Grid.Column="1" 
                                          Glyph="{x:Bind Icon}" 
                                          FontSize="16" 
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                          VerticalAlignment="Center"/>

                                <!-- Text Details -->
                                <StackPanel Grid.Column="3" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Subtitle}" 
                                               Style="{ThemeResource CaptionTextBlockStyle}" 
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Priority Tag -->
                                <Border Grid.Column="4" 
                                        Background="{ThemeResource ControlFillColorDefaultBrush}" 
                                        CornerRadius="4" 
                                        Padding="6,2" 
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Priority, Mode=OneWay}" 
                                               Style="{ThemeResource CaptionTextBlockStyle}" 
                                               FontFamily="Consolas" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- About Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="About" Style="{ThemeResource SubtitleTextBlockStyle}" />
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1" 
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                        CornerRadius="8" 
                        Padding="16">
                    <StackPanel Spacing="12">
                        <Grid>
                            <TextBlock Text="Version" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Text="1.0.0" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        </Grid>
                        <HyperlinkButton Content="Send Feedback / GitHub" NavigateUri="https://github.com/VibeNoobNotFound/Glotto" Padding="0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
