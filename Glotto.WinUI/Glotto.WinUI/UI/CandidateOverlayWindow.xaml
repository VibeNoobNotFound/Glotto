<?xml version="1.0" encoding="utf-8"?>
<!-- CandidateOverlayWindow.xaml
     Port of CandidatePanelView.swift — the floating transliteration candidate panel.
     
     Key design notes:
     - No SystemBackdrop (Acrylic/Mica) — known WinUI 3 bug: backdrop doesn't render
       on non-activated windows, which this always is by design. Use plain Border instead.
     - Background is a semi-transparent dark/light color that still reads over varied backgrounds.
     - Script text at 18pt, chrome at 10-13pt — matching the macOS panel sizing.
     - Selected candidate row gets accent color highlight.
-->
<Window
    x:Class="Glotto.WinUI.UI.CandidateOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Glotto.WinUI.UI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="">

    <Border x:Name="RootBorder"
            CornerRadius="14"
            Background="Transparent"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Padding="0"
            MaxWidth="320"
            MinWidth="200"
            Opacity="0.0">

        <Border.Resources>
            <Storyboard x:Name="ShowStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootBorder"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.0" To="1.0"
                                 Duration="0:0:0.12">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="RootBorderTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="-8.0" To="0.0"
                                 Duration="0:0:0.12">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="HideStoryboard">
                <DoubleAnimation Storyboard.TargetName="RootBorder"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.0"
                                 Duration="0:0:0.10">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="RootBorderTransform"
                                 Storyboard.TargetProperty="Y"
                                 To="-6.0"
                                 Duration="0:0:0.10">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseIn"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Border.Resources>

        <Border.RenderTransform>
            <TranslateTransform x:Name="RootBorderTransform" Y="-8.0" />
        </Border.RenderTransform>

        <Border.Shadow>
            <ThemeShadow />
        </Border.Shadow>

        <StackPanel>
            <!-- Header row: icon + buffer text badge + lookup failed indicator + profile name -->
            <Grid x:Name="HeaderRow"
                  Padding="12,8,12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Keyboard icon -->
                <FontIcon Grid.Column="0"
                          Glyph="&#xE92E;"
                          FontSize="11"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                          Margin="0,0,6,0" />

                <!-- Buffer text badge -->
                <Border Grid.Column="1"
                        x:Name="BufferBadge"
                        CornerRadius="4"
                        Padding="5,2,5,2"
                        Margin="0,0,4,0"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        Opacity="0.15"
                        Visibility="Collapsed">
                    <TextBlock x:Name="BufferText"
                               FontSize="13"
                               FontWeight="Bold"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                </Border>

                <!-- Lookup failed indicator -->
                <FontIcon Grid.Column="2"
                          x:Name="LookupFailedIcon"
                          Glyph="&#xEB5E;"
                          FontSize="10"
                          Foreground="Orange"
                          Margin="0,0,4,0"
                          Visibility="Collapsed" />

                <!-- Profile name -->
                <TextBlock Grid.Column="4"
                           x:Name="ProfileNameText"
                           FontSize="10"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- Thin separator -->
            <Rectangle Height="1"
                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                       Opacity="0.4" />

            <!-- Loading state -->
            <StackPanel x:Name="LoadingPanel"
                        Orientation="Horizontal"
                        Padding="12,10,12,10"
                        Spacing="8"
                        Visibility="Collapsed">
                <ProgressRing Width="16" Height="16" IsActive="True" />
                <TextBlock x:Name="LoadingText"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyText"
                       Text="Type to transliterate…"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Padding="12,10,12,10"
                       Visibility="Collapsed" />

            <!-- Candidates list -->
            <StackPanel x:Name="CandidatesPanel"
                        Padding="0,4,0,4"
                        Visibility="Collapsed">
                <!-- Populated dynamically in code-behind -->
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
